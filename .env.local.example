# Copie este arquivo para .env.local e preencha.

# Claude — obrigatório para prompts de CÓDIGO e IA/TEXTO
ANTHROPIC_API_KEY=sk-ant-...

# Gemini — obrigatório para prompts de IMAGEM e VÍDEO (+ análise de imagens)
# Obtenha em: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# Modelos Gemini (Flash ≈ 5–10× mais barato que Pro)
# Geração de prompts (o usuário também pode trocar na UI)
GEMINI_MODEL=gemini-2.5-flash
# Análise de imagens de referência (sempre separado — não usa o modelo da UI)
GEMINI_VISION_MODEL=gemini-2.5-flash

# Opcional — histórico/favoritos no Google Sheets via Apps Script.
# Veja google-apps-script/Code.gs para criar a URL.
SHEETS_WEBAPP_URL=
# Opcional — senha que protege a URL do Apps Script (precisa ser igual à do script)
SHEETS_TOKEN=
